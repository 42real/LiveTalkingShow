# Priority: ENV (highest) > .env (fallback) > config.yaml (lowest)
# Copy this file to .env before starting services.

# Optional config controls
# LIVETALKING_CONFIG_PATH=config.yaml
# LIVETALKING_ENV_FILE=.env

# Runtime
HF_ENDPOINT=https://hf-mirror.com

# Service network
# If this port changes, update all client URLs that point to LiveTalking:
# LIVETALKING_URL/LIVETALKING_WS_URL in this file and testclient/.env,
# plus VITE_LIVETALKING_URL, VITE_ALPHA_INPUT_WS and LIVETALKING_SERVER.
LIVETALKING_HOST=0.0.0.0
LIVETALKING_PORT=8050
LIVETALKING_URL=http://127.0.0.1:8050
LIVETALKING_WS_URL=ws://127.0.0.1:8050
LIVETALKING_MAX_SESSION=1

# Avatar/model
# AVATAR_ID is the directory name under data/avatars/.
# Avatar files are ignored by Git and must be downloaded or copied separately.
LIVETALKING_MODEL=wav2lip
AVATAR_ID=wav2lip_avatar_female_model
LIVETALKING_BATCH_SIZE=4
LIVETALKING_FPS=25
LIVETALKING_L=10
LIVETALKING_M=8
LIVETALKING_R=10
LIVETALKING_MODELRES=192
LIVETALKING_MODELFILE=
LIVETALKING_CUSTOMVIDEO_CONFIG=

# Output
# Keep transport as webrtc for the local alpha/display handoff.
# Alpha transparent output is controlled by LIVETALKING_ALPHA_OUTPUT, not by
# setting LIVETALKING_TRANSPORT=alpha.
LIVETALKING_TRANSPORT=webrtc
LIVETALKING_PUSH_URL=http://localhost:1985/rtc/v1/whip/?app=live&stream=livestream
LIVETALKING_ALPHA_OUTPUT=1
LIVETALKING_OUTPUT_METRICS_INTERVAL=5

# TTS
# Must point to a robottts-compatible service. If the TTS port changes, also
# update VITE_TTS_SERVER_URL in testclient/.env.
LIVETALKING_TTS=robottts
REF_FILE=zh-CN-YunxiaNeural
REF_TEXT=
ROBOTTTS_MODE=instruct2
ROBOTTTS_CONNECT_TIMEOUT=10
ROBOTTTS_RECEIVE_TIMEOUT=1
TTS_SERVER_URL=http://127.0.0.1:8036

# Motion planning LLM
# Used by POST /motion/plan. Keep real keys in .env, not in Git.
MOTION_LLM_BASE_URL=
MOTION_LLM_MODEL=
# MOTION_LLM_API_KEY=
# MOTION_LLM_TIMEOUT=30

# Motion source safety
# Absolute source paths are only accepted under these roots.
# Separate multiple paths with the platform path separator.
# MOTION_ALLOWED_SOURCE_DIRS=tmp/uploaded_sources:data
# MOTION_UPLOAD_MAX_BYTES=536870912
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe
