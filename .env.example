# Copy this file to .env and source it before starting services:
#   set -a
#   source .env
#   set +a

# LiveTalking runtime
export HF_ENDPOINT=https://hf-mirror.com
export LIVETALKING_MODEL=wav2lip
export AVATAR_ID=default_calm_1
export LIVETALKING_HOST=0.0.0.0
export LIVETALKING_PORT=8050
export LIVETALKING_URL=http://127.0.0.1:8050
export LIVETALKING_WS_URL=ws://127.0.0.1:8050
export LIVETALKING_BATCH_SIZE=4
export LIVETALKING_ALPHA_OUTPUT=1

# Unified robottts-compatible TTS service.
# LiveTalking should normally use:
#   --tts robottts --TTS_SERVER "$TTS_SERVER_URL"
export TTS_SERVER_URL=http://127.0.0.1:8036
