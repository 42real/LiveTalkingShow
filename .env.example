# LiveTalking 部署覆盖配置模板
#
# 使用方式：复制本文件为 .env，然后按当前机器或部署环境修改取值。
#
# config.yaml 是团队共享、可提交的默认配置中心，适合放稳定策略和底层默认值。
# .env 只建议放本机/部署覆盖项，例如端口、avatar、TTS 地址、batch size、
# 密钥和少量部署级开关。
#
# 本文件不是 config.yaml 的完整镜像。模型底层参数、推流细节和调试开关通常保持
# config.yaml 或代码默认值；确实需要按部署覆盖时再追加环境变量。
#
# 配置优先级：ENV > .env > config.yaml


# ---------------------------------------------------------------------------
# 配置入口和运行时网络
# ---------------------------------------------------------------------------

# 配置文件路径。类型：string。
# 可填相对路径或绝对路径；相对路径按仓库根目录解析。
LIVETALKING_CONFIG_PATH=config.yaml

# Hugging Face 下载端点。类型：http/https URL。
# 国内环境建议 https://hf-mirror.com；能直连时也可改为官方端点或留给 config.yaml。
HF_ENDPOINT=https://hf-mirror.com


# ---------------------------------------------------------------------------
# 服务绑定
# ---------------------------------------------------------------------------

# HTTP/WebSocket 监听地址。类型：IP 或 hostname。
# 常用值：0.0.0.0 表示允许远程访问；127.0.0.1 表示只允许本机访问。
LIVETALKING_HOST=0.0.0.0

# HTTP/WebSocket 端口。类型：int，范围 1-65535。
# 修改后需要同步测试客户端和显示端访问地址。
LIVETALKING_PORT=8050

# 最大并发 session 数。类型：int，范围 >=1。
# 当前 alpha 桌面显示链路通常只需要 1；多路并发时再调大。
LIVETALKING_MAX_SESSION=1


# ---------------------------------------------------------------------------
# Avatar 和推理
# ---------------------------------------------------------------------------

# 数字人后端模型。类型：枚举。
# 可选值：wav2lip、musetalk、ultralight。
LIVETALKING_MODEL=wav2lip

# avatar 目录名。类型：string。
# 实际路径为 data/avatars/<AVATAR_ID>/；avatar 素材不提交到 Git。
AVATAR_ID=wav2lip_avatar_female_model

# 推理 batch size。类型：int，范围 >=1，常用 1-16。
# 值越小交互延迟越低；值越大吞吐可能更好但显存占用和等待时间更高。
LIVETALKING_BATCH_SIZE=4

# 内部视频帧率。类型：int，范围 >0。
# LiveTalking/Wav2Lip 资产通常按 25fps 制作，除非素材和链路都确认支持，否则不建议改。
LIVETALKING_FPS=25


# ---------------------------------------------------------------------------
# 输出
# ---------------------------------------------------------------------------

# 基础输出传输方式。类型：枚举。
# 可选值：webrtc、rtmp、rtcpush、virtualcam。
# 本地 alpha/Web/overlay 显示链路建议保持 webrtc。
LIVETALKING_TRANSPORT=webrtc

# 是否启用 alpha 显示接口。类型：bool。
# 可填：1/0、true/false、yes/no、on/off。
# 开启后提供 /alpha/input/audio、/alpha/webrtc/packed_offer、/alpha/ws、/alpha/audio。
LIVETALKING_ALPHA_OUTPUT=1


# ---------------------------------------------------------------------------
# TTS
# ---------------------------------------------------------------------------

# TTS 插件。类型：枚举。
# 交接主链路使用 robottts；其他原 LiveTalking 插件仅在明确需要时使用。
# 常见可选值：robottts、edgetts、cosyvoice、gpt-sovits、fishtts、tencent、
# doubao、indextts2、azuretts、qwentts。
LIVETALKING_TTS=robottts

# robottts 兼容 TTS 服务 HTTP 地址。类型：http/https URL。
# 默认测试客户端 TTS 端口为 8036；生产环境改成真实 robot-tts 地址。
TTS_SERVER_URL=http://127.0.0.1:8036

# robottts 模式。类型：string，由 TTS 服务解释。
# 当前测试客户端常用 instruct2；如真实 TTS 支持 zero-shot 等模式，可按其协议填写。
ROBOTTTS_MODE=instruct2


# ---------------------------------------------------------------------------
# 动作素材和编排
# ---------------------------------------------------------------------------

# 同一状态下多个动作素材的选择策略。类型：枚举。
# 可选值：
# sequence：按顺序循环；
# random：完全随机；
# weighted_random：按素材权重随机；
# no_repeat_random：随机但避免连续重复；
# weighted_no_repeat：按权重随机并避免连续重复。
LIVETALKING_MOTION_STRATEGY=weighted_no_repeat

# /motion/plan 可选 LLM 配置。类型：URL/string/secret。
# 只在使用动作规划接口时需要；真实密钥写入 .env，不提交到 Git。
MOTION_LLM_BASE_URL=
MOTION_LLM_MODEL=
# MOTION_LLM_API_KEY=
