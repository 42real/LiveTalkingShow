# Copy to .env and source it before using testclient scripts:
#   set -a
#   source .env
#   set +a

# LiveTalking service under test
export LIVETALKING_URL=http://127.0.0.1:8050
export LIVETALKING_WS_URL=ws://127.0.0.1:8050
export LIVETALKING_SERVER=http://127.0.0.1:8050

# Self-contained robottts-compatible test TTS backend
export TEST_TTS_PROVIDER=edge
export TTS_SERVICE_HOST=0.0.0.0
export TTS_SERVICE_PORT=8036
export TTS_SERVER_URL=http://127.0.0.1:8036
export TTS_DEFAULT_MODE=instruct2
export TTS_STREAM_SAMPLE_RATE=16000
export TTS_STREAM_CHUNK_MS=40
export TEST_TTS_CORS_ORIGIN="*"

# EdgeTTS provider
export ROBOT_TTS_EDGE_VOICES=zh-CN-XiaoxiaoNeural,zh-CN-YunxiNeural,zh-CN-YunxiaNeural,zh-CN-YunjianNeural,en-US-JennyNeural
export ROBOT_TTS_EDGE_RATE=+0%
export ROBOT_TTS_EDGE_VOLUME=+0%
export ROBOT_TTS_EDGE_PITCH=+0Hz

# Bailian provider. Only needed when TEST_TTS_PROVIDER=bailian.
export DASHSCOPE_API_KEY=
export BAILIAN_COSYVOICE_MODEL=cosyvoice-v3-flash
export BAILIAN_VOICES=longanyang,longanhuan,longhuhu_v3
export BAILIAN_INSTRUCTION_FIELD=instructions
export BAILIAN_USE_PROMPTS_AS_INSTRUCTIONS=1

# Browser visual test client
export TEST_CLIENT_HOST=0.0.0.0
export TEST_CLIENT_PORT=8070
export VITE_LIVETALKING_URL=http://127.0.0.1:8050
export VITE_TTS_SERVER_URL=http://127.0.0.1:8036
export VITE_ALPHA_INPUT_WS=ws://127.0.0.1:8050/alpha/input/audio

# Desktop overlay test window
export ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/
export LIVETALKING_PLAY_AUDIO=0
export LIVETALKING_CLICK_THROUGH=1
export LIVETALKING_AUTO_SESSION=1
export LIVETALKING_CLOSE_SESSION_ON_EXIT=0
export LIVETALKING_SCALE=1
export LIVETALKING_RENDERER=webgl
export LIVETALKING_CONTROL_WIDTH=340
export LIVETALKING_CONTROL_HEIGHT=38
