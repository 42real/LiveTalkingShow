# LiveTalking testclient 覆盖配置模板
#
# 使用方式：在 testclient/ 目录复制本文件为 .env，然后按当前测试机器修改取值。
#
# testclient/ 是独立测试包，不读取 LiveTalking 主服务 .env，也没有自己的 config.yaml。
# start-tts.sh、start-web.sh、start-overlay.sh 会把 testclient/.env 当作默认值加载；
# 已经由外部 export 的 ENV 不会被 .env 覆盖。
#
# 配置优先级：ENV > testclient/.env > 代码默认值
#
# 本文件只暴露日常测试需要修改的配置。显示帧率、编码格式、渲染器等属于高级排障项，
# 需要时看 testclient/README.md 后用临时 ENV 覆盖。


# ---------------------------------------------------------------------------
# 被测试的 LiveTalking 服务
# ---------------------------------------------------------------------------

# 浏览器可访问的 LiveTalking HTTP 地址。类型：http/https URL。
# 远程浏览器访问时，127.0.0.1 指浏览器所在机器，不一定是服务器。
VITE_LIVETALKING_URL=http://127.0.0.1:8050

# TTS task 推送 PCM 音频的 WebSocket 目标。类型：ws/wss URL。
# 必须指向 LiveTalking 的 /alpha/input/audio；端口要和 LIVETALKING_PORT 对齐。
VITE_ALPHA_INPUT_WS=ws://127.0.0.1:8050/alpha/input/audio

# overlay 可访问的 LiveTalking HTTP 地址。类型：http/https URL。
# overlay 跑在另一台显示机器时，改成推理机 IP 或域名。
LIVETALKING_SERVER=http://127.0.0.1:8050


# ---------------------------------------------------------------------------
# 自带 robottts 兼容测试 TTS 后端
# ---------------------------------------------------------------------------

# 测试 TTS provider。类型：枚举。
# 可选值：edge、bailian。edge 使用 EdgeTTS；bailian 使用百炼 CosyVoice。
TEST_TTS_PROVIDER=edge

# 测试 TTS 监听地址。类型：IP 或 hostname。
# 0.0.0.0 允许远程访问；127.0.0.1 只允许本机访问。
TTS_SERVICE_HOST=0.0.0.0

# 测试 TTS 端口。类型：int，范围 1-65535。
TTS_SERVICE_PORT=8036

# TTS HTTP 地址。类型：http/https URL。
# TTS_SERVER_URL 给脚本和本机联调用；VITE_TTS_SERVER_URL 给浏览器页面使用。
TTS_SERVER_URL=http://127.0.0.1:8036
VITE_TTS_SERVER_URL=http://127.0.0.1:8036

# TTS 输出给 LiveTalking 的 PCM 采样率。类型：int，单位 Hz。
# 当前 LiveTalking 音频输入链路按 16000Hz mono PCM16 对接，建议保持 16000。
TTS_STREAM_SAMPLE_RATE=16000

# TTS 推流 chunk 时长。类型：int，单位 ms，代码下限 20。
# 常用 20-80；越小延迟越低但 WebSocket 包更多，越大越稳但首包和口型响应更慢。
TTS_STREAM_CHUNK_MS=40

# EdgeTTS 音色列表。类型：逗号分隔 string list。
# 请求里的 voice_id 是该列表的下标，从 0 开始；超出范围会报错。
ROBOT_TTS_EDGE_VOICES=zh-CN-XiaoxiaoNeural,zh-CN-YunxiNeural,zh-CN-YunxiaNeural,zh-CN-YunjianNeural,en-US-JennyNeural

# 百炼 API Key。类型：secret。
# 仅 TEST_TTS_PROVIDER=bailian 时必填；也兼容 BAILIAN_API_KEY。
DASHSCOPE_API_KEY=

# 百炼 CosyVoice 模型名。类型：string。
# 默认 cosyvoice-v3-flash；可按百炼当前开通模型填写。
BAILIAN_COSYVOICE_MODEL=cosyvoice-v3-flash

# 百炼音色列表。类型：逗号分隔 string list。
# 请求里的 voice_id 是该列表的下标，从 0 开始。
BAILIAN_VOICES=longanyang,longanhuan,longhuhu_v3


# ---------------------------------------------------------------------------
# 浏览器 Web 测试页
# ---------------------------------------------------------------------------

# Web 测试页监听地址。类型：IP 或 hostname。
TEST_CLIENT_HOST=0.0.0.0

# Web 测试页端口。类型：int，范围 1-65535。
TEST_CLIENT_PORT=8070

# 动作制作/动作管理页默认 avatar id。类型：string，可为空。
# 为空时主测试页优先使用当前 LiveTalking session；需要离线管理动作素材时可填写。
VITE_AVATAR_ID=

# Web 视频输出模式。类型：枚举。
# 可选值：
# webrtc-packed：推荐，POST /alpha/webrtc/packed_offer，单 WebRTC 视频轨携带 color+alpha；
# ws：旧调试链路，使用 /alpha/ws 和 /alpha/audio。
VITE_ALPHA_OUTPUT=webrtc-packed

# Web 是否播放 LiveTalking 输出音频。类型：bool，0 或 1。
# 只开启一个播放端，避免 Web、overlay 或系统播放器重复出声。
VITE_ALPHA_PLAY_AUDIO=0

# Web 视频目标帧率。类型：float，0 或 >0。
# 0 表示使用 avatar 原始输出节奏；远程带宽不足时可试 12-15。
VITE_ALPHA_VIDEO_FPS=0

# packed WebRTC 浏览器渲染器。类型：枚举，webgl 或 2d。
# webgl 性能更好；浏览器不支持时页面会自动回退到 2d。
VITE_ALPHA_RENDERER=webgl


# ---------------------------------------------------------------------------
# 桌面 overlay 测试窗口
# ---------------------------------------------------------------------------

# Electron 下载镜像。类型：http/https URL。
# 国内 npm 安装 Electron 较慢时保留该镜像；能直连时可删掉或改官方镜像。
ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/

# overlay 视频输出模式。类型：枚举。
# 可选值：ws、webrtc-packed。
# 本机 overlay 推荐 ws；远程显示推荐 webrtc-packed。
LIVETALKING_OUTPUT=ws

# raw websocket 帧格式。类型：枚举。
# 可选值：bgra、raw/rgba/rgba8、jpeg、jpg、png、webp。
# 本机 overlay 推荐 bgra，可避免服务端每帧做 BGRA->RGBA 转换。
LIVETALKING_VIDEO_FORMAT=bgra

# 视频窗口是否鼠标穿透。类型：bool，0 或 1。
# 1：鼠标点击穿透到后面的 PPT/桌面；0：窗口可直接点击和拖动。
LIVETALKING_CLICK_THROUGH=1

# overlay 是否播放 LiveTalking 输出音频。类型：bool，0 或 1。
# 通常保持 0，由 Web 或业务端统一播放，避免重复声音。
LIVETALKING_PLAY_AUDIO=0

# overlay 初始显示倍率。类型：float，范围 >0，常用 0.5-2.0。
# 只影响窗口显示大小，不改变 avatar 原始推理尺寸。
LIVETALKING_SCALE=1
