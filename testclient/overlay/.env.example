# Copy to .env before running ./start.sh if you want local defaults.
# LIVETALKING_SERVER must point to a LiveTalking service with
# LIVETALKING_ALPHA_OUTPUT=1. If overlay runs on another device, use the
# reachable server IP/domain instead of 127.0.0.1.
export ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/
export LIVETALKING_SERVER=http://127.0.0.1:8050
export LIVETALKING_CLICK_THROUGH=1
export LIVETALKING_PLAY_AUDIO=0
export LIVETALKING_AUTO_SESSION=1
export LIVETALKING_CLOSE_SESSION_ON_EXIT=0
export LIVETALKING_WIDTH=360
export LIVETALKING_HEIGHT=640
export LIVETALKING_SCALE=1
export LIVETALKING_RENDERER=webgl
export LIVETALKING_CONTROL_WIDTH=340
export LIVETALKING_CONTROL_HEIGHT=38
export LIVETALKING_VIDEO_MAX_WIDTH=0
export LIVETALKING_VIDEO_MAX_HEIGHT=1080
export LIVETALKING_VIDEO_FPS=15
export LIVETALKING_VIDEO_FORMAT=raw
export LIVETALKING_VIDEO_QUALITY=80
export LIVETALKING_X=1200
export LIVETALKING_Y=200
export LIVETALKING_EXTRA_PATH=
