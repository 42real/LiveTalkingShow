# 浏览器 Web 测试页覆盖配置模板
#
# 通常建议使用 testclient/.env 并从 testclient/ 执行 ./start-web.sh。
# 本文件只用于直接进入 testclient/web 运行 Vite 的场景。
#
# 配置优先级：Vite 启动时的 ENV/web/.env > 代码默认值
# 修改任何 VITE_* 后都需要重启 Web 测试页。

# 浏览器可访问的 LiveTalking HTTP 地址。类型：http/https URL。
# 远程浏览器访问时，127.0.0.1 指浏览器所在机器。
VITE_LIVETALKING_URL=http://127.0.0.1:8050

# 浏览器可访问的 TTS HTTP 地址。类型：http/https URL。
VITE_TTS_SERVER_URL=http://127.0.0.1:8036

# TTS task 推送 PCM 音频的 WebSocket 目标。类型：ws/wss URL。
# 必须指向 LiveTalking 的 /alpha/input/audio。
VITE_ALPHA_INPUT_WS=ws://127.0.0.1:8050/alpha/input/audio

# 动作制作/动作管理页默认 avatar id。类型：string，可为空。
VITE_AVATAR_ID=

# Web 视频输出模式。类型：枚举。
# 可选值：
# webrtc-packed：推荐，POST /alpha/webrtc/packed_offer，单 WebRTC 视频轨携带 color+alpha；
# ws：本机调试链路，使用 /alpha/ws 和 /alpha/audio。
VITE_ALPHA_OUTPUT=webrtc-packed

# ws 模式的视频帧格式。类型：枚举，常用 bgra/raw/jpeg/png/webp。
# bgra 避免服务端每帧 BGRA->RGBA 转换。
VITE_ALPHA_VIDEO_FORMAT=bgra

# Web 是否播放 LiveTalking 输出音频。类型：bool，0 或 1。
VITE_ALPHA_PLAY_AUDIO=0

# 页面表单默认文本。类型：string。
VITE_DEFAULT_TEXT=这是一段 robottts 兼容接口流式测试。

# 页面表单默认朗读提示词。类型：string。
VITE_DEFAULT_PROMPTS=请自然清晰地朗读。

# 页面表单默认音色下标。类型：int，范围 >=0 且小于当前 TTS voices 数量。
VITE_DEFAULT_VOICE_ID=0

# 页面表单默认 TTS 模式。类型：string，由 TTS 服务解释；测试客户端常用 instruct2。
VITE_DEFAULT_MODE=instruct2
