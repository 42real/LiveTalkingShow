## Browser-side test client config.
## Restart ./start-web.sh after changing any VITE_* value.
## If the browser is remote, 127.0.0.1 means the browser machine.
VITE_LIVETALKING_URL=http://127.0.0.1:8050
VITE_TTS_SERVER_URL=http://127.0.0.1:8036
VITE_ALPHA_INPUT_WS=ws://127.0.0.1:8050/alpha/input/audio
VITE_ALPHA_AUDIO_SAMPLE_RATE=16000
VITE_ALPHA_VIDEO_MAX_HEIGHT=0
VITE_ALPHA_VIDEO_FPS=25
VITE_VIDEO_RENDER_INTERVAL_MS=40
VITE_ALPHA_AUTO_CONNECT=1
VITE_DEFAULT_TEXT=这是一段 robottts 兼容接口流式测试。
VITE_DEFAULT_PROMPTS=请自然清晰地朗读。
VITE_DEFAULT_VOICE_ID=0
VITE_DEFAULT_MODE=instruct2
